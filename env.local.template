# Copy to .env.local (repo root), then restart `npm run dev`.
# cp env.local.template .env.local

# Required for real signups: service role JWT (Dashboard → Project Settings → API → service_role).
# Also set your project URL so the server can reach Supabase (Dashboard → Project Settings → API → Project URL).
NEXT_PUBLIC_SUPABASE_URL=
# IMPORTANT: Never commit real service role keys.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: middleware / future client (publishable or anon key)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional: email notification per signup
# RESEND_API_KEY=
# RESEND_FROM=
# WAITLIST_NOTIFY_EMAIL=
