# ─── Site URL (SEO / sitemap / JSON-LD) ─────────────────────────────────────
# Production: set to your public domain so sitemap, canonical, and Open Graph use it.
# NEXT_PUBLIC_SITE_URL=https://autodsm.ai

# ─── Supabase (https://supabase.com/dashboard) ──────────────────────────────
# Table + dashboard steps: lib/waitlist/SUPABASE_DASHBOARD.md and lib/waitlist/schema.sql
# Quick local setup: cp env.local.template .env.local → add SUPABASE_SERVICE_ROLE_KEY → restart dev.
# Public URL defaults in next.config.ts for this repo; override with NEXT_PUBLIC_SUPABASE_URL if needed.
NEXT_PUBLIC_SUPABASE_URL=https://qihitweosezlsjgyytdd.supabase.co
# Legacy name; either works:
NEXT_PUBLIC_SUPABASE_ANON_KEY=sbp_0987654321
# Or newer publishable key from dashboard:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only — required for /api/waitlist → inserts into waitlist_signups (never expose to client).
# Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Legacy alias (optional): persistSupabaseWaitlist also accepts SUPABASE_URL if NEXT_PUBLIC is unset.
# SUPABASE_URL=

# ─── Waitlist email (optional) ────────────────────────────────────────────────
# RESEND_API_KEY=
# RESEND_FROM="AutoDSM <onboarding@resend.dev>"
# WAITLIST_NOTIFY_EMAIL=
