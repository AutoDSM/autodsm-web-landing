# ─── Supabase (https://supabase.com/dashboard) ──────────────────────────────
# Table + dashboard steps: lib/waitlist/SUPABASE_DASHBOARD.md and lib/waitlist/schema.sql
# Public — safe for NEXT_PUBLIC_* (used by SSR middleware + browser helpers).
NEXT_PUBLIC_SUPABASE_URL=
# Legacy name; either works:
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Or newer publishable key from dashboard:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only — required for /api/waitlist → inserts into waitlist_signups (never expose to client).
# Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Legacy alias (optional): persistSupabaseWaitlist also accepts SUPABASE_URL if NEXT_PUBLIC is unset.
# SUPABASE_URL=

# ─── Waitlist email (optional) ────────────────────────────────────────────────
# RESEND_API_KEY=
# RESEND_FROM="AutoDSM <onboarding@resend.dev>"
# WAITLIST_NOTIFY_EMAIL=
